# =============================================================================
# FeedbackFlow Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control
#
# For detailed setup instructions, see: README.md
# =============================================================================

# -----------------------------------------------------------------------------
# Convex (Required)
# -----------------------------------------------------------------------------
# Get these from: https://dashboard.convex.dev
# After running `npx convex dev`, these will be automatically generated
CONVEX_DEPLOYMENT=your-deployment-name
NEXT_PUBLIC_CONVEX_URL=https://your-public-clerk-url.convex.cloud

# -----------------------------------------------------------------------------
# Clerk Authentication (Required)
# -----------------------------------------------------------------------------
# Get these from: https://dashboard.clerk.com
# 1. Create a new application
# 2. Copy the API keys from the "API Keys" section
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk Issuer URL (for Convex auth)
# Format: https://your-app-name-XX.clerk.accounts.dev
# Find this in Clerk Dashboard > API Keys > Advanced > Issuer URL
CLERK_ISSUER_URL=https://your-clerk-instance.clerk.accounts.dev

# -----------------------------------------------------------------------------
# Stripe (Optional - for billing features)
# -----------------------------------------------------------------------------
# Get these from: https://dashboard.stripe.com/apikeys
# Use test keys for development, live keys for production
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs (create these in Stripe Dashboard > Products)
STRIPE_PRICE_PRO_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_PRO_YEARLY=price_xxxxxxxxxxxxxxxxxxxxx

# Stripe Webhook Secret (from Stripe Dashboard > Webhooks)
# Run `stripe listen --forward-to localhost:3000/api/webhooks/stripe` for local testing
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Resend (Optional - for email notifications)
# -----------------------------------------------------------------------------
# Get this from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email "from" address (must be verified in Resend)
EMAIL_FROM=FeedbackFlow <noreply@yourdomain.com>

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
# Your application's public URL (used in emails and webhooks)
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# AI Provider API Keys (Optional - set in Convex, not here)
# -----------------------------------------------------------------------------
# Users provide their own OpenAI/Anthropic keys through the dashboard
# These are encrypted and stored in Convex
# DO NOT set these here - they should be configured per-team in the app
#
# To set system-wide defaults (for testing), use Convex environment variables:
# npx convex env set OPENAI_API_KEY sk-proj-xxxxxxxxxxxxxxxxxxxxx
# npx convex env set ANTHROPIC_API_KEY sk-ant-xxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Storage Configuration (Optional - for S3/R2/GCS)
# -----------------------------------------------------------------------------
# By default, FeedbackFlow uses Convex storage
# Configure these only if you want to use external storage
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=
# S3_BUCKET=
# S3_ENDPOINT= (for R2 or custom S3-compatible storage)

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------
# Set to "development" for local development
NODE_ENV=development
