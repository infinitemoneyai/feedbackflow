{
  "compilerOptions": {
    "allowJs": true,
    "strict": true,
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "module": "ESNext",
    "target": "ESNext",
    "noEmit": true,
    "paths": {
      "@/*": ["../*"]
    },
    "typeRoots": ["../node_modules/@types"]
  },
  "include": ["./**/*.ts", "./**/*.tsx", "../node_modules/.bin/convex-env.d.ts"],
  "exclude": ["./node_modules", "./_generated"]
}
